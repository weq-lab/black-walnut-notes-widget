<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="22dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="위젯 설정" android:textColor="#5A3021" android:textSize="27sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="표시할 소스" android:textColor="#5A3021" android:textStyle="bold" />
        <Spinner android:id="@+id/spinner_widget_source" android:layout_width="match_parent" android:layout_height="52dp" android:backgroundTint="#75432E" android:popupBackground="#120904" />
        <LinearLayout android:id="@+id/local_note_section" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="로컬 노트" android:textColor="#5A3021" />
            <Spinner android:id="@+id/spinner_widget_note" android:layout_width="match_parent" android:layout_height="52dp" android:backgroundTint="#75432E" android:popupBackground="#120904" />
        </LinearLayout>
        <LinearLayout android:id="@+id/file_note_section" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
            <Button android:id="@+id/button_choose_file" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:backgroundTint="#D1AE6F" android:text="TXT / Markdown 파일 선택" android:textColor="#2A1710" />
            <TextView android:id="@+id/text_selected_file" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="선택한 파일 없음" android:textColor="#75432E" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="색상 프리셋" android:textColor="#5A3021" android:textStyle="bold" />
        <Spinner android:id="@+id/spinner_color_preset" android:layout_width="match_parent" android:layout_height="52dp" android:backgroundTint="#75432E" android:popupBackground="#120904" />
        <EditText android:id="@+id/edit_background" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="배경 #000000" android:inputType="textNoSuggestions" android:textColor="#75432E" android:textColorHint="#29150F" />
        <EditText android:id="@+id/edit_title_color" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="제목 #5A3021" android:inputType="textNoSuggestions" android:textColor="#75432E" android:textColorHint="#29150F" />
        <EditText android:id="@+id/edit_body_color" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="본문 #3A2017" android:inputType="textNoSuggestions" android:textColor="#75432E" android:textColorHint="#29150F" />
        <EditText android:id="@+id/edit_accent_color" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="강조 #D1AE6F" android:inputType="textNoSuggestions" android:textColor="#75432E" android:textColorHint="#29150F" />
        <EditText android:id="@+id/edit_text_size" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="본문 크기 16" android:inputType="numberDecimal" android:textColor="#75432E" />
        <Button android:id="@+id/button_save" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:backgroundTint="#D1AE6F" android:text="저장하고 위젯 만들기" android:textColor="#2A1710" />
    </LinearLayout>
</ScrollView>
