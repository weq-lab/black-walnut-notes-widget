<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="기본함"
            android:textColor="#5A3021"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_refresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="새로고침"
            android:padding="8dp"
            android:src="@drawable/ic_refresh" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="top|start"
        android:lineSpacingExtra="4dp"
        android:maxLines="30"
        android:paddingTop="12dp"
        android:text="할 일 없음"
        android:textColor="#3A2017"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="6dp">

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="갱신 --:--"
            android:textColor="#29150F"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/widget_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="위젯 설정"
            android:padding="7dp"
            android:src="@drawable/ic_settings" />
    </LinearLayout>
</LinearLayout>
