<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="7dp"
    android:paddingEnd="14dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:fontFamily="@font/maruburi_semibold"
            android:maxLines="1"
            android:text="제목 없음"
            android:textColor="#5A3021"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/widget_collapse"
            android:layout_width="28dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="본문 접기"
            android:padding="6dp"
            android:scaleType="center"
            android:src="@drawable/ic_chevron_up" />

        <ImageButton
            android:id="@+id/widget_new"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="새 노트"
            android:padding="0dp"
            android:scaleType="center"
            android:src="@drawable/ic_add" />

        <ImageButton
            android:id="@+id/widget_refresh"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="새로고침"
            android:padding="0dp"
            android:scaleType="center"
            android:src="@drawable/ic_refresh" />

        <ImageButton
            android:id="@+id/widget_settings"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="설정"
            android:padding="0dp"
            android:scaleType="center"
            android:src="@drawable/ic_settings" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:fadeScrollbars="true"
        android:scrollbarDefaultDelayBeforeFade="300"
        android:scrollbarFadeDuration="300"
        android:scrollbarSize="2dp"
        android:scrollbarStyle="insideOverlay"
        android:scrollbarThumbVertical="@drawable/widget_scrollbar_thumb"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:text="위젯 설정에서 노트를 선택하세요"
        android:textColor="#75432E"
        android:textSize="14sp" />
</LinearLayout>
