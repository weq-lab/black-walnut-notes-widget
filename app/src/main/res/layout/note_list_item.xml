<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#070302"
    android:minHeight="92dp"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:id="@+id/note_row_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLines="1" android:ellipsize="end" android:textSize="19sp" android:textStyle="bold" />
    <TextView android:id="@+id/note_row_preview" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:maxLines="2" android:ellipsize="end" android:textSize="14sp" />
    <TextView android:id="@+id/note_row_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:textSize="11sp" />
</LinearLayout>
