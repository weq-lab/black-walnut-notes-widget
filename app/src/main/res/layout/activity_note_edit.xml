<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <EditText android:id="@+id/edit_note_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#5A3021" android:hint="제목" android:inputType="textCapSentences" android:maxLines="2" android:textColor="#5A3021" android:textColorHint="#29150F" android:textSize="26sp" android:textStyle="bold" />
        <EditText android:id="@+id/edit_note_body" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:backgroundTint="#3A2017" android:gravity="top|start" android:hint="노트를 입력하세요" android:inputType="textCapSentences|textMultiLine" android:minHeight="140dp" android:textColor="#75432E" android:textColorHint="#29150F" android:textSize="17sp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="체크리스트" android:textColor="#5A3021" android:textSize="17sp" android:textStyle="bold" />
        <LinearLayout android:id="@+id/checklist_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        <Button android:id="@+id/button_add_check_item" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#3A2017" android:text="+ 체크 항목" android:textColor="#D1AE6F" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="색상 프리셋" android:textColor="#5A3021" android:textStyle="bold" />
        <Spinner android:id="@+id/edit_note_preset" android:layout_width="match_parent" android:layout_height="52dp" android:backgroundTint="#75432E" android:popupBackground="#120904" />
        <TextView android:id="@+id/auto_save_status" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="불러오는 중…" android:textColor="#D1AE6F" android:textSize="12sp" />
        <Button android:id="@+id/button_delete_note" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:backgroundTint="#30110D" android:text="노트 삭제" android:textColor="#C76D3E" />
    </LinearLayout>
</ScrollView>
