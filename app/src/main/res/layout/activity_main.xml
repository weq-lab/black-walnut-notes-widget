<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Black Walnut Notes"
        android:textColor="#5A3021"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_new_note"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#D1AE6F"
            android:text="+ 새 노트"
            android:textColor="#201008" />

        <Button
            android:id="@+id/button_add_widget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:backgroundTint="#5A3021"
            android:text="위젯 추가"
            android:textColor="#D1AE6F" />
    </LinearLayout>

    <ListView
        android:id="@+id/note_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:divider="#1A0D08"
        android:dividerHeight="1dp" />

    <TextView
        android:id="@+id/note_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="새 노트를 만들어 보세요.\nTXT/Markdown 파일은 위젯 설정에서 계속 사용할 수 있습니다."
        android:textAlignment="center"
        android:textColor="#75432E"
        android:textSize="16sp" />
</LinearLayout>
